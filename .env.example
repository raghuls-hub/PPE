# PPE Attendance System - Environment Configuration
# Copy this file to .env and customize as needed

# MongoDB
MONGODB_URI=mongodb://localhost:27017
DB_NAME=ppe_attendance

# Face Recognition (LBPH confidence - lower is better, threshold is max allowed)
FACE_MATCH_THRESHOLD=70

# PPE Detection
PPE_CONFIDENCE_THRESHOLD=0.45
PPE_IOU_THRESHOLD=0.45

# Fire Detection (uses hf_firedetection.pt)
FIRE_DETECTION_ENABLED=true
FIRE_CONFIDENCE_THRESHOLD=0.40
FIRE_IOU_THRESHOLD=0.45
FIRE_ALERT_COOLDOWN_SEC=5.0

# Fall Detection (uses fall_detection.pt)
FALL_DETECTION_ENABLED=true
FALL_CONFIDENCE_THRESHOLD=0.50
FALL_IOU_THRESHOLD=0.45
FALL_FRAME_THRESHOLD=10
FALL_ALERT_COOLDOWN_FRAMES=30

# Attendance
ATTENDANCE_COOLDOWN_MINUTES=5

# Camera
CAMERA_INDEX=0
FRAME_WIDTH=1280
FRAME_HEIGHT=720

# Features
SAVE_SNAPSHOTS=true
SOUND_ENABLED=true
PROCESS_EVERY_N_FRAMES=3
