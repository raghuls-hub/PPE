# ═══════════════════════════════════════════════════════════════════
#  CCTV AI Admin Dashboard — Environment Variables
#  Copy this file to .env and fill in your values.
#  All constants are sourced from here; do NOT hard-code in code.
# ═══════════════════════════════════════════════════════════════════

# ── MongoDB Atlas ──────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=ppe_attendance

# ── Model filenames (must exist in project root) ───────────────────
PPE_MODEL_FILE=PPE_detection.pt
FALL_MODEL_FILE=fall_detection.pt
FIRE_MODEL_FILE=fire_detection.pt

# ── PPE Detection ──────────────────────────────────────────────────
PPE_CONFIDENCE_THRESHOLD=0.45
PPE_IOU_THRESHOLD=0.45
# Consecutive frames without required PPE before alert fires
PPE_VIOLATION_THRESHOLD=15

# ── Fire Detection ─────────────────────────────────────────────────
FIRE_CONFIDENCE_THRESHOLD=0.40
FIRE_IOU_THRESHOLD=0.45
# Consecutive frames with fire before alert fires
FIRE_FRAME_THRESHOLD=5

# ── Fall Detection ─────────────────────────────────────────────────
FALL_CONFIDENCE_THRESHOLD=0.50
FALL_IOU_THRESHOLD=0.45
# Consecutive frames with fall-class before alert fires
FALL_FRAME_THRESHOLD=10
# Frames to keep alert active after last fall frame
FALL_ALERT_COOLDOWN=30

# ── Face Recognition ───────────────────────────────────────────────
# Lower = stricter. LBPH confidence (0–300). 120 is a good default.
FACE_MATCH_THRESHOLD=120

# ── Attendance ─────────────────────────────────────────────────────
# Minutes before same employee can be marked again
ATTENDANCE_COOLDOWN_MINUTES=5
# Run detection every N frames (reduces CPU load)
PROCESS_EVERY_N_FRAMES=3
